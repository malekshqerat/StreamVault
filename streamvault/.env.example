# URL of the stalker-proxy server
# For local dev the proxy runs on port 3001 by default
VITE_PROXY_URL=http://localhost:3001

# Optional: CF Worker URL for catalog API and Stalker proxy
# VITE_CATALOG_URL=https://your-worker.your-subdomain.workers.dev

# Optional: Separate stream proxy URL (defaults to VITE_PROXY_URL)
# VITE_STREAM_PROXY_URL=https://your-proxy.koyeb.app
